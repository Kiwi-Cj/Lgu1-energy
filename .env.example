APP_NAME="Lgu1 Energy"
APP_ENV=production
INTEGRATION_API_TOKEN=
APP_KEY=
APP_DEBUG=true
APP_URL=https://energy.infragovservices.com
PUBLIC_UPLOAD_ROOT=/home/energy.infragovservices.com/public_html

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=ener_lgu
DB_USERNAME=ener_root
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=60
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=energyconservemgmt@gmail.com
MAIL_FROM_NAME="energy"

ADMIN_SUPPORT_EMAIL=
ADMIN_SUPPORT_PHONE="+1 (555) 123-4567"

PASSWORD_RESET_LINK_EXPIRE=5
PASSWORD_RESET_LINK_THROTTLE=5
OTP_EXPIRE_MINUTES=1

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

AI_RECOMMENDATIONS_ENABLED=true
AI_RECOMMENDATIONS_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT=10
OPENAI_TEMPERATURE=0.2
OPENAI_MAX_TOKENS=180

MAIN_METER_SENSOR_TOKEN=
SUBMETER_SENSOR_TOKEN=

# SSO — must match SSO_SECRET_ENERGY in Main LGU's .env
SSO_SHARED_SECRET=

# CIMM <-> Energy maintenance synchronization token.
# Must match ENERGY_MAINTENANCE_SYNC_TOKEN on the CIMM side.
CIMM_MAINTENANCE_SYNC_TOKEN=
MQTT_HOST=127.0.0.1
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=lgu-energy-laravel-subscriber
MQTT_SUBMETER_TOPIC=lgu/submeters/+/telemetry
MQTT_QOS=0
MQTT_KEEP_ALIVE=10
MQTT_CONNECT_TIMEOUT=60
MQTT_SOCKET_TIMEOUT=5
